<Window x:Class="Vesper.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Vesper.Helpers"
        Title="VESPER — Settings" Height="600" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:EnumBooleanConverter x:Key="EnumConverter"/>
        <helpers:BoolToCaptureTextConverter x:Key="BoolToCapture"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Recognition Mode -->
                <GroupBox Header="Recognition Mode" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <RadioButton Content="Toggle (click to start/stop)"
                                     IsChecked="{Binding Mode, Converter={StaticResource EnumConverter}, ConverterParameter=Toggle}"
                                     Margin="0,2"/>
                        <RadioButton Content="Push-to-Talk (hold key)"
                                     IsChecked="{Binding Mode, Converter={StaticResource EnumConverter}, ConverterParameter=PushToTalk}"
                                     Margin="0,2"/>
                        <RadioButton Content="Continuous (always listening)"
                                     IsChecked="{Binding Mode, Converter={StaticResource EnumConverter}, ConverterParameter=Continuous}"
                                     Margin="0,2"/>
                        <RadioButton Content="Streaming (real-time paste)"
                                     IsChecked="{Binding Mode, Converter={StaticResource EnumConverter}, ConverterParameter=Streaming}"
                                     Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

                <!-- Speech Backend -->
                <GroupBox Header="Speech Backend" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <RadioButton Content="Local (offline)" GroupName="Backend"
                                     IsChecked="{Binding Backend, Converter={StaticResource EnumConverter}, ConverterParameter=Local}"
                                     Margin="0,2"/>
                        <RadioButton Content="OpenAI API (online)" GroupName="Backend"
                                     IsChecked="{Binding Backend, Converter={StaticResource EnumConverter}, ConverterParameter=Api}"
                                     Margin="0,2"/>
                        <RadioButton Content="Local API Server (any model)" GroupName="Backend"
                                     IsChecked="{Binding Backend, Converter={StaticResource EnumConverter}, ConverterParameter=LocalApi}"
                                     Margin="0,2"/>

                        <!-- API Key (visible only for API mode) -->
                        <StackPanel Visibility="{Binding IsApiMode, Converter={StaticResource BoolToVis}}"
                                    Margin="0,6,0,0">
                            <TextBlock Text="API Key:" Margin="0,0,0,2"/>
                            <PasswordBox x:Name="ApiKeyBox" MaxLength="200"
                                         PasswordChanged="ApiKeyBox_PasswordChanged"/>
                        </StackPanel>

                        <!-- Local API config (visible only for LocalApi mode) -->
                        <StackPanel Visibility="{Binding IsLocalApiMode, Converter={StaticResource BoolToVis}}"
                                    Margin="0,6,0,0">
                            <TextBlock Text="Server URL:" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding LocalApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,6"/>
                            <TextBlock Text="Model name (optional):" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding LocalApiModelName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,4"/>
                            <TextBlock Text="Uses OpenAI-compatible /v1/audio/transcriptions endpoint.&#x0a;Works with: faster-whisper-server, LocalAI, whisper.cpp server,&#x0a;or any ASR model wrapped in a compatible API."
                                       FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Model Selection (for local backend) -->
                <GroupBox Header="Speech Model" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableModels}"
                                      SelectedItem="{Binding SelectedModel}"
                                      Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Download"
                                    Command="{Binding DownloadModelCommand}"
                                    Width="80"/>
                        </Grid>

                        <TextBlock Text="{Binding SelectedModelInfo, Mode=OneWay}"
                                   FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>

                        <!-- Download progress -->
                        <StackPanel Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                                    Margin="0,6,0,0">
                            <ProgressBar Minimum="0" Maximum="100"
                                         Value="{Binding DownloadProgress, Mode=OneWay}" Height="16"/>
                            <TextBlock Text="{Binding DownloadStatus, Mode=OneWay}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>

                        <TextBlock Text="{Binding IsModelDownloaded, Mode=OneWay, StringFormat='Model downloaded: {0}'}"
                                   FontSize="11" Margin="0,4,0,0" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- Language -->
                <GroupBox Header="Language" Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding Languages}"
                              SelectedValue="{Binding SelectedLanguage}"
                              SelectedValuePath="Code"
                              DisplayMemberPath="Name"
                              Margin="4"/>
                </GroupBox>

                <!-- Hotkey -->
                <GroupBox Header="Hotkey" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding HotkeyDisplay, Mode=OneWay}"
                                     IsReadOnly="True" Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="{Binding IsCapturingHotkey, Converter={StaticResource BoolToCapture}}"
                                    Click="CaptureHotkey_Click" Width="80"/>
                        </Grid>
                        <TextBlock Text="Click 'Set', then press desired key combination"
                                   FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>

                        <!-- Auto-Enter after paste -->
                        <CheckBox Content="Auto-press Enter after pasting text"
                                  IsChecked="{Binding AutoEnterAfterPaste}"
                                  Margin="0,8,0,0"/>

                        <!-- Second hotkey -->
                        <CheckBox Content="Enable second hotkey (recognition + Enter)"
                                  IsChecked="{Binding Hotkey2Enabled}"
                                  Margin="0,8,0,2"/>
                        <Grid Margin="0,2,0,0"
                              IsEnabled="{Binding Hotkey2Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Hotkey2Display, Mode=OneWay}"
                                     IsReadOnly="True" Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="{Binding IsCapturingHotkey2, Converter={StaticResource BoolToCapture}}"
                                    Click="CaptureHotkey2_Click" Width="80"/>
                        </Grid>
                        <TextBlock Text="This hotkey always sends Enter after pasting, regardless of the checkbox above"
                                   FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Microphone -->
                <GroupBox Header="Microphone" Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding AvailableDevices}"
                              SelectedIndex="{Binding SelectedDeviceIndex}"
                              Margin="4"/>
                </GroupBox>

                <!-- VAD Settings -->
                <GroupBox Header="Voice Detection (Continuous mode)" Margin="0,0,0,8">
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding VadThresholdDb, StringFormat='Sensitivity: {0:F0} dB'}" />
                        <Slider Minimum="-60" Maximum="-10"
                                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,4,0,8"
                                Value="{Binding VadThresholdDb}"/>

                        <TextBlock Text="{Binding VadSilenceMs, StringFormat='Silence timeout: {0:F0} ms'}" />
                        <Slider Minimum="300" Maximum="3000"
                                TickFrequency="100" IsSnapToTickEnabled="True" Margin="0,4,0,0"
                                Value="{Binding VadSilenceMs}"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Click="Save_Click"
                    Width="80" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
